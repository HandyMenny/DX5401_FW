Source-Makefile: package/system/mmc_over_gpio/Makefile
Package: kmod-mmc-over-gpio
Menu: 1
Submenu: Other modules
Version: <LINUX_VERSION>-4
Depends: @GPIO_SUPPORT +kmod-mmc-spi +kmod-spi-gpio-old
Menu-Depends: 
Provides: 
Section: kernel
Category: Kernel modules
Title: MMC/SD card over GPIO support
Maintainer: 
Source: 
Type: ipkg
Kernel-Config: CONFIG_GPIOMMC CONFIG_CONFIGFS_FS=y
Description:  Support for driving an MMC/SD card over GPIO pins via SPI.

@@
Config:
	menu "Configuration"
		depends on PACKAGE_kmod-mmc-over-gpio

	config KMOD_MMC_OVER_GPIO_DI_PIN
		int "GPIO DI (Data-In) pin"
		default 1

	config KMOD_MMC_OVER_GPIO_DO_PIN
		int "GPIO DO (Data-Out) pin"
		default 3

	config KMOD_MMC_OVER_GPIO_CLK_PIN
		int "GPIO CLK (Clock) pin"
		default 4

	config KMOD_MMC_OVER_GPIO_CS_PIN
		int "GPIO CS (Chip-Select) pin"
		default 7

	endmenu
@@


Source-Makefile: package/system/hostap-driver/Makefile
Package: kmod-hostap
Submenu: Wireless Drivers
Version: <LINUX_VERSION>--2
Depends: @PCI_SUPPORT||PCMCIA_SUPPORT +kmod-lib80211 +wireless-tools
Menu-Depends: 
Provides: 
Section: kernel
Category: Kernel modules
Title: Host AP support for Prism2/2.5/3
Maintainer: 
Source: hostap-driver-0.4.9.tar.gz
Type: ipkg
Kernel-Config: CONFIG_HOSTAP CONFIG_HOSTAP_FIRMWARE=y CONFIG_HOSTAP_FIRMWARE_NVRAM=y
Description:  Host AP is a driver for 802.11b wireless cards based on Intersil 
 Prism2/2.5/3 chipset. It supports so called Host AP mode that allows the 
 card to act as an IEEE 802.11 access point.
 This package contains the base Host AP driver code that is shared by 
 different hardware models. You will also need to enable support for 
 PLX/PCI/CS version of the driver to actually use the driver.
http://hostap.epitest.fi/

@@

Package: kmod-hostap-cs
Submenu: Wireless Drivers
Version: <LINUX_VERSION>--2
Depends: @PCMCIA_SUPPORT +kmod-hostap +kmod-pcmcia-core
Menu-Depends: 
