	config PACKAGE_kmod-w1-slave-ds2760
		tristate "kmod-w1-slave-ds2760. Dallas 2760 battery monitor chip (HP iPAQ & others)"
		default y if DEFAULT_kmod-w1-slave-ds2760
		default m if ALL
