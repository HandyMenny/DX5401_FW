		 http://www.kernel.org/pub/linux/utils/util-linux/
		 

	config PACKAGE_external-kernel-ldconfig
		tristate "external-kernel-ldconfig............... Shared library path configuration"
		default y if DEFAULT_external-kernel-ldconfig
		default m if ALL
		depends on EXTERNAL_KERNEL_TOOLCHAIN
