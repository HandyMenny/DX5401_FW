		config EXTERNAL_KERNAL_LDCONFIG_FILE_SPEC
			string
			prompt "ldconfig file"
			depends on EXTERNAL_KERNEL_TOOLCHAIN && PACKAGE_external-kernel-ldconfig
			default "./sbin/ldconfig"
	
		endmenu

