		 http://sourceforge.net/projects/et131x
		 

	config PACKAGE_kmod-gigaset
		tristate "kmod-gigaset...................... Siemens Gigaset support for isdn4linux"
		default y if DEFAULT_kmod-gigaset
		default m if ALL
		depends on USB_SUPPORT
		select PACKAGE_kmod-lib-crc-ccitt
		select PACKAGE_kmod-isdn4linux
		select PACKAGE_kmod-usb-core
		help
		 This driver supports the Siemens Gigaset SX205/255 family of
		  ISDN DECT bases, including the predecessors Gigaset 3070/3075
