		select PACKAGE_libcares
		select PACKAGE_libpthread if USE_GLIBC
		help
		 Command line client tools for publishing messages to MQTT servers
		 and subscribing to topics.
		         This package is built without SSL support
		 http://www.mosquitto.org/
		 Karl Palsson <karlp@etactica.com>

	config PACKAGE_mosquitto-client-ssl
		tristate "mosquitto-client-ssl......... mosquitto - client tools (With SSL support)"
		default y if DEFAULT_mosquitto-client-ssl
		default m if ALL
		select PACKAGE_libmosquitto-ssl
		select PACKAGE_libc
		select PACKAGE_libcares
		select PACKAGE_libpthread if USE_GLIBC
