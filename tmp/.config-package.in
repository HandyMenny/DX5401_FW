menu "W1 support"
	config PACKAGE_kmod-w1
		tristate "kmod-w1.......................................... Dallas's 1-wire support"
		default y if DEFAULT_kmod-w1
		default m if ALL
		help
		 Kernel module for Dallas's 1-wire support
		 

	config PACKAGE_kmod-w1-gpio-custom
		tristate "kmod-w1-gpio-custom...................... Custom GPIO-based 1-wire device"
		default y if DEFAULT_kmod-w1-gpio-custom
