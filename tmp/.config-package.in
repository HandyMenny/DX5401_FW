		depends on (!(TARGET_avr32||TARGET_etrax)||BROKEN)
		select PACKAGE_iw
		depends on (!(TARGET_avr32||TARGET_ps3||TARGET_pxcab)||BROKEN)
		help
		 cfg80211 is the Linux wireless LAN (802.11) configuration API.
		 http://linuxwireless.org/
		 Felix Fietkau <nbd@openwrt.org>

	config PACKAGE_kmod-hostap
		tristate "kmod-hostap............................. Host AP support for Prism2/2.5/3"
		default y if DEFAULT_kmod-hostap
		default m if ALL
		select PACKAGE_wireless-tools
		depends on PCI_SUPPORT||PCMCIA_SUPPORT
		depends on (!(TARGET_avr32||TARGET_ps3||TARGET_pxcab)||BROKEN)
		select PACKAGE_kmod-lib80211
		help
		 Host AP is a driver for 802.11b wireless cards based on Intersil 
		  Prism2/2.5/3 chipset. It supports so called Host AP mode that allows the 
		  card to act as an IEEE 802.11 access point.
		  This package contains the base Host AP driver code that is shared by 
		  different hardware models. You will also need to enable support for 
		  PLX/PCI/CS version of the driver to actually use the driver.
		 http://hostap.epitest.fi/
		 

	config PACKAGE_kmod-hostap-cs
		tristate "kmod-hostap-cs........................ Host AP driver for PCMCIA adaptors"
		default y if DEFAULT_kmod-hostap-cs
		default m if ALL
		depends on PCMCIA_SUPPORT
		select PACKAGE_kmod-hostap
		select PACKAGE_kmod-pcmcia-core
		depends on PCI_SUPPORT||PCMCIA_SUPPORT
		depends on (!(TARGET_avr32||TARGET_ps3||TARGET_pxcab)||BROKEN)
		help
		 Host AP is a driver for 802.11b wireless cards based on Intersil 
		  Prism2/2.5/3 chipset. It supports so called Host AP mode that allows the 
		  card to act as an IEEE 802.11 access point.
		  This package contains the Host AP driver for Prism2/2.5/3 PC cards.
		 http://hostap.epitest.fi/
		 

	config PACKAGE_kmod-hostap-pci
		tristate "kmod-hostap-pci.......................... Host AP driver for PCI adaptors"
		default y if DEFAULT_kmod-hostap-pci
		default m if ALL
		depends on PCI_SUPPORT||PCMCIA_SUPPORT
		depends on (!(TARGET_avr32||TARGET_ps3||TARGET_pxcab)||BROKEN)
		depends on PCI_SUPPORT
		select PACKAGE_kmod-hostap
		help
		 Host AP is a driver for 802.11b wireless cards based on Intersil 
		  Prism2/2.5/3 chipset. It supports so called Host AP mode that allows the 
		  card to act as an IEEE 802.11 access point.
		  This package contains the Host AP driver for Prism2.5 PCI adaptors.
		 http://hostap.epitest.fi/
		 

	config PACKAGE_kmod-hostap-plx
		tristate "kmod-hostap-plx............ Host AP driver for PLX9052 based PCI adaptors"
		default y if DEFAULT_kmod-hostap-plx
		default m if ALL
		depends on PCI_SUPPORT
		select PACKAGE_kmod-hostap
		depends on (!(TARGET_avr32||TARGET_ps3||TARGET_pxcab)||BROKEN)
		depends on PCI_SUPPORT||PCMCIA_SUPPORT
		help
		 Host AP is a driver for 802.11b wireless cards based on Intersil 
		  Prism2/2.5/3 chipset. It supports so called Host AP mode that allows the 
		  card to act as an IEEE 802.11 access point.
		  This package contains the Host AP driver for Prism2/2.5/3 in PLX9052 
		  based PCI adaptors.
		 http://hostap.epitest.fi/
		 

