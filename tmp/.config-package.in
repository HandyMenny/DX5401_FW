		select PACKAGE_libexif
		select PACKAGE_libflac
		select PACKAGE_libintl-full if BUILD_NLS
		select PACKAGE_libuuid
		select PACKAGE_libiconv-full if BUILD_NLS
		select PACKAGE_libpthread
		select PACKAGE_libid3tag
		select PACKAGE_libc
		select PACKAGE_libsqlite3
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libvorbis
		depends on PACKAGE_libffmpeg-custom||PACKAGE_libffmpeg-full||PACKAGE_libffmpeg-mini
		help
		 MiniDLNA (aka ReadyDLNA) is server software with the aim of
		   being fully compliant with DLNA/UPnP-AV clients.
		 http://minidlna.sourceforge.net/
		 

endmenu

menu "Administration"

	config PACKAGE_rport
		tristate "rport................................... Remote Management (RMM) Software"
		default y if DEFAULT_rport
		default m if ALL
		select PACKAGE_libc
		select PACKAGE_uuidgen
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_libpthread
		select PACKAGE_librt if USE_GLIBC
		help
		 Rport helps you to manage your remote servers without the hassle of VPNs,
		 	chained SSH connections, jump-hosts, or the use of commercial tools like
		 	TeamViewer and its clones.
		 https://github.com/cloudradar-monitoring/rport
		 

	config PACKAGE_syslog-ng
		tristate "syslog-ng....................................... A powerful syslog daemon"
		default y if DEFAULT_syslog-ng
		default m if ALL
		select PACKAGE_libc
		select PACKAGE_glib2
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_librt if USE_GLIBC
		help
		 syslog-ng reads and logs messages to the system console, log
		 	files, other machines and/or users as specified by its
		 	configuration file.
		 http://www.balabit.com/products/syslog_ng/
		 


		select PACKAGE_libzcfg_msg if PACKAGE_zcfg
		select PACKAGE_libzcmd_tool if PACKAGE_zcfg
		select PACKAGE_libjson if PACKAGE_zcfg
		select PACKAGE_libzcfg_fe_rdm_access if PACKAGE_zcfg
		select PACKAGE_libzcfg_fe_rdm_struct if PACKAGE_zcfg
		select PACKAGE_libzcfg_fe_dal if PACKAGE_zcfg

endmenu

