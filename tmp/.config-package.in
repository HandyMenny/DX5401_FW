		select PACKAGE_external-kernel-librt if EXTERNAL_KERNEL_TOOLCHAIN
		select PACKAGE_libc
		select PACKAGE_external-kernel-libpthread if EXTERNAL_KERNEL_TOOLCHAIN
		select PACKAGE_external-kernel-libc if EXTERNAL_KERNEL_TOOLCHAIN
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_external-kernel-libgcc if EXTERNAL_KERNEL_TOOLCHAIN
		help
		 General netlink utility frontend
		 http://linux-net.osdl.org/index.php/Iproute2
		 

	config PACKAGE_hostap-utils
		tristate "hostap-utils............................. Host AP driver utility programs"
		default y if DEFAULT_hostap-utils
		default m if ALL
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_librt if USE_GLIBC
		depends on PACKAGE_kmod-hostap
		select PACKAGE_libc
		help
		 Host AP driver utility programs
		 http://hostap.epitest.fi/
		 

	config PACKAGE_hostapd
		tristate "hostapd................................. IEEE 802.1x Authenticator (full)"
		default y if DEFAULT_hostapd
		default m if ALL
		select PACKAGE_libnl-tiny if PACKAGE_kmod-mac80211
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libc
		depends on (!(TARGET_avr32||TARGET_etrax)||BROKEN)
		help
		 This package contains a full featured IEEE 802.1x/WPA/EAP/RADIUS
		  Authenticator.
		 http://hostap.epitest.fi/
		 Felix Fietkau <nbd@openwrt.org>

	config PACKAGE_hostapd-mini
		tristate "hostapd-mini.................... IEEE 802.1x Authenticator (WPA-PSK only)"
		default y if DEFAULT_hostapd-mini
		default m if ALL
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libnl-tiny if PACKAGE_kmod-mac80211
		select PACKAGE_libpthread if USE_GLIBC
		depends on (!(TARGET_avr32||TARGET_etrax)||BROKEN)
		select PACKAGE_libc
		help
		 This package contains a minimal IEEE 802.1x/WPA Authenticator (WPA-PSK only).
		 http://hostap.epitest.fi/
		 Felix Fietkau <nbd@openwrt.org>

	config PACKAGE_hostapd-utils
		tristate "hostapd-utils.......................... IEEE 802.1x Authenticator (utils)"
		default y if DEFAULT_hostapd-utils
		default m if ALL
		select PACKAGE_libc
		depends on PACKAGE_hostapd||PACKAGE_hostapd-mini||PACKAGE_wpad||PACKAGE_wpad-mini
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libpthread if USE_GLIBC
		help
		 This package contains a command line utility to control the
		  IEEE 802.1x/WPA/EAP/RADIUS Authenticator.
		 http://hostap.epitest.fi/
		 Felix Fietkau <nbd@openwrt.org>

	config PACKAGE_ifenslave
		tristate "ifenslave........ A utility to manipulate kernel ethernet bonding devices"
		default y if DEFAULT_ifenslave
		default m if ALL
		select PACKAGE_libc
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_kmod-bonding
		select PACKAGE_libpthread if USE_GLIBC
		help
		 ifenslave is needed to add/remove interfaces to/from ethernet bond devices.
		 http://www.kernel.org
		 

	config PACKAGE_iftop
		tristate "iftop............................. display bandwith usage on an interface"
		default y if DEFAULT_iftop
		default m if ALL
		select PACKAGE_libncurses
		select PACKAGE_libpthread
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libc
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_libpcap
		help
		 iftop does for network usage what top(1) does for CPU usage. It 
		 	listens to network traffic on a named interface and displays a 
		 	table of current bandwidth usage by pairs of hosts. Handy for 
		 	answering the question 'why is our ADSL link so slow?'.
		 http://www.ex-parrot.com/~pdw/iftop/
		 Jo-Philipp Wich <jow@openwrt.org>

	config PACKAGE_iperf
		tristate "iperf......................... Internet Protocol bandwidth measuring tool"
		default y if DEFAULT_iperf
		default m if ALL
		select PACKAGE_libc
		depends on !(USE_LIBSTDCXX) || INSTALL_LIBSTDCPP
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_libstdcpp if USE_LIBSTDCXX
		select PACKAGE_libiperf
		depends on !(USE_UCLIBCXX) || INSTALL_LIBSTDCPP
		select PACKAGE_libpthread
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_librt
		select PACKAGE_uclibcxx if USE_UCLIBCXX
		help
		 Iperf is a modern alternative for measuring TCP and UDP bandwidth
		  performance, allowing the tuning of various parameters and
		  characteristics.
		 https://github.com/esnet/iperf
		 Felix Fietkau <nbd@nbd.name>

	config PACKAGE_ipset
		tristate "ipset....................................... IPset administration utility"
		default y if DEFAULT_ipset
		default m if ALL
		select PACKAGE_libmnl
		depends on (!(TARGET_ps3||TARGET_pxcab)||BROKEN)
