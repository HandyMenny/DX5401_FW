		tristate "ip6tables.............................. IPv6 firewall administration tool"
		default y if DEFAULT_ip6tables
		default m if ALL
		select PACKAGE_libc
		select PACKAGE_libxtables
		select PACKAGE_kmod-ip6tables
		select PACKAGE_libpthread if USE_GLIBC
