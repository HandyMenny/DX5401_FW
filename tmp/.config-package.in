	config PACKAGE_OWAMP
		tristate "OWAMP....... A tool for performing one-way or two-way active measurements"
		default y if DEFAULT_OWAMP
		default m if ALL
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libc
		help
		 This release is contains implementations of the OWAMP (one-way active measurement protocol)
		   defined by https://tools.ietf.org/html/rfc4656 and the TWAMP (two-way active measurement protocol)
		   defined by https://tools.ietf.org/html/rfc5357.
		 https://github.com/perfsonar/owamp
		 

	config PACKAGE_bwm
		tristate "bwm........................................ A very tiny bandwidth monitor"
		default y if DEFAULT_bwm
		default m if ALL
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libc
		help
		 A very tiny bandwidth monitor
		 http://ftp.debian.org/debian/pool/main/b/bwm
		 

	config PACKAGE_chat
		tristate "chat................................. Establish conversation with a modem"
		default y if DEFAULT_chat
		default m if ALL
		select PACKAGE_libjson
		select PACKAGE_librt if USE_GLIBC
		depends on (PACKAGE_ppp)
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_libc
		select PACKAGE_libzcfg_msg
		help
		 This package contains an utility to establish conversation with other PPP servers
		 (via a modem).
		 http://ppp.samba.org/
		 Jo-Philipp Wich <xm@subsignal.org>

	config PACKAGE_genl
		tristate "genl.................................... General netlink utility frontend"
		default y if DEFAULT_genl
