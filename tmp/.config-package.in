menuconfig IMAGEOPT
	bool "Image configuration"
	default n
source "package/*/image-config.in"
menu "Base system"

	config PACKAGE_base-files
		tristate "base-files................................... Base filesystem for OpenWrt"
		default y if DEFAULT_base-files
		default m if ALL
		select PACKAGE_libc
		select PACKAGE_procd
		select PACKAGE_netifd
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libpthread if USE_GLIBC
		help
		 This package contains a base filesystem and system scripts for OpenWrt.
		 http://openwrt.org/
		 

	config PACKAGE_base-files-econet
		tristate "base-files-econet........................ Base filesystem for Econdet SDK"
		default y if DEFAULT_base-files-econet
		default m if ALL
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_libc
		help
		 This package contains a base filesystem and system scripts.
		 

	config PACKAGE_base-files-ramips
		tristate "base-files-ramips................ Base filesystem for MTK ramips platform"
		default y if DEFAULT_base-files-ramips
		default m if ALL
		select PACKAGE_libc
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_librt if USE_GLIBC
		help
		 This package contains a base filesystem and system scripts.
		 

	menuconfig PACKAGE_block-mount
		tristate "block-mount........................... Block device mounting and checking"
		default y if DEFAULT_block-mount
		default m if ALL
		select PACKAGE_libc
		select PACKAGE_blkid
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_swap-utils
		select PACKAGE_librt if USE_GLIBC
		help
		 Scripts used to mount and check block devices (filesystems and swap), as well
		   as hotplug scripts to automount and check block devices when hotplug event (e.g.
		   from plugging in a device) occurs.
		   Also includes preinit scripts for mounting a block device as the root filesystem.
		   This allows one to have the root filesystem on devices other than the built in flash
		   device.
		 


		source "package/block-mount/Config.in"

	config PACKAGE_bridge
		tristate "bridge........................... Ethernet bridging configuration utility"
		default y if DEFAULT_bridge
		default m if ALL
		select PACKAGE_libc
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libpthread if USE_GLIBC
		help
		 Manage ethernet bridging: a way to connect networks together to 
		  form a larger network.
		 http://bridge.sourceforge.net/
		 

	menuconfig PACKAGE_busybox
		tristate "busybox................................ Core utilities for embedded Linux"
		default y if DEFAULT_busybox
		default m if ALL
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_librpc if BUSYBOX_CONFIG_FEATURE_HAVE_RPC
		select PACKAGE_libc
		help
		 The Swiss Army Knife of embedded Linux.
		  It slices, it dices, it makes Julian Fries.
		 http://busybox.net/
		 Nicolas Thill <nico@openwrt.org>


		source "package/busybox/Config.in"

	config PACKAGE_dhcpoptinj
		tristate "dhcpoptinj"
		default y if DEFAULT_dhcpoptinj
		default m if ALL
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_libnfnetlink
		select PACKAGE_libc
		select PACKAGE_libnetfilter_queue
		help
		 A deamon to receive and handle dhcp opt82 insertion via NF_QUEUE
		 

	menuconfig PACKAGE_dnsmasq
		tristate "dnsmasq................................ A lightweight DNS and DHCP server"
		default y if DEFAULT_dnsmasq
		default m if ALL
		select PACKAGE_libc
		select PACKAGE_nettle if dnsmasq_dnssec
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libpthread if USE_GLIBC
		help
		 It is intended to provide coupled DNS and DHCP service to a LAN.
		 http://www.thekelleys.org.uk/dnsmasq/
		 


		select PACKAGE_libzcfg_msg if PACKAGE_zcfg
		select PACKAGE_esmd if PACKAGE_zcfg
		select PACKAGE_nettle if dnsmasq_dnssec
		deselect PACKAGE_nettle if !dnsmasq_dnssec
		deselect dnsmasq_dnssec if dnsmasq_releaseno=2.67
		source "package/network/services/dnsmasq/Config.in"

	config PACKAGE_dnsmasq-dhcpv6
		tristate "dnsmasq-dhcpv6... A lightweight DNS and DHCP server (with DHCPv6 support)"
		default y if DEFAULT_dnsmasq-dhcpv6
		default m if ALL
		select PACKAGE_libc
		select PACKAGE_kmod-ipv6
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_librt if USE_GLIBC
		depends on IPV6
		help
		 It is intended to provide coupled DNS and DHCP service to a LAN.
		 
		 This is a variant with DHCPv6 support
		 http://www.thekelleys.org.uk/dnsmasq/
		 

	config PACKAGE_dropbear
		tristate "dropbear........................................ Small SSH2 client/server"
		default y if DEFAULT_dropbear
		default m if ALL
		select PACKAGE_libopenssl
		select PACKAGE_libjson
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libubootenv
		select PACKAGE_libzcfg_fe_rdm_struct
		select PACKAGE_libcrypto
		select PACKAGE_libzyutil
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_libzcfg_fe_rdm_access
		select PACKAGE_libc
		select PACKAGE_libzcfg_msg
		select PACKAGE_libzcmd_tool
		help
		 A small SSH2 server/client designed for small memory environments.
		 http://matt.ucc.asn.au/dropbear/
		 

	config PACKAGE_ead
		tristate "ead.............................................. Emergency Access Daemon"
		default y if DEFAULT_ead
		default m if ALL
		select PACKAGE_libc
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libpthread if USE_GLIBC
		help
		 Provides remote access to your device even if IP and firewall
		   configuration settings are defunct
		 http://bridge.sourceforge.net/
		 Felix Fietkau <nbd@openwrt.org>

	config PACKAGE_external-kernel-libc
		tristate "external-kernel-libc........................... External kernel C library"
		default y if DEFAULT_external-kernel-libc
		default m if ALL
		select PACKAGE_external-kernel-libgcc
		depends on EXTERNAL_KERNEL_TOOLCHAIN
		help
		 External kernel C library
		 Felix Fietkau <nbd@openwrt.org>


		menu "Configuration"
		depends on EXTERNAL_KERNEL_TOOLCHAIN && PACKAGE_external-kernel-libc
	
		config EXTERNAL_KERNAL_LIBC_FILE_SPEC
			string
			prompt "external-kernel-libc shared library files (use wildcards)"
			depends on EXTERNAL_KERNEL_TOOLCHAIN && PACKAGE_external-kernel-libc
			default "./lib/lib{anl,c,uClibc,cidn,crypt,dl,m,nsl,nss_dns,nss_files,util}{-*.so,.so.*}"
	
		endmenu

	config PACKAGE_external-kernel-libgcc
		tristate "external-kernel-libgcc............... External kernel gcc support library"
		default y if DEFAULT_external-kernel-libgcc
		default m if ALL
		depends on EXTERNAL_KERNEL_TOOLCHAIN
		help
		 External kernel gcc support library
		 http://gcc.gnu.org/
		 Felix Fietkau <nbd@openwrt.org>


		menu "Configuration"
			depends on EXTERNAL_KERNEL_TOOLCHAIN && PACKAGE_external-kernel-libgcc
	
		config EXTERNAL_KERNAL_LIBGCC_FILE_SPEC
			string
			prompt "libgcc shared library files (use wildcards)"
			depends on EXTERNAL_KERNEL_TOOLCHAIN && PACKAGE_external-kernel-libgcc
			default "./lib/libgcc_s.so.*"
	
		endmenu

	config PACKAGE_external-kernel-libpthread
		tristate "external-kernel-libpthread.......................... POSIX thread library"
		default y if DEFAULT_external-kernel-libpthread
		default m if ALL
		select PACKAGE_external-kernel-libgcc
		depends on EXTERNAL_KERNEL_TOOLCHAIN
		help
		 POSIX thread library
		 Felix Fietkau <nbd@openwrt.org>


		menu "Configuration"
		depends on EXTERNAL_KERNEL_TOOLCHAIN && PACKAGE_external-kernel-libpthread
	
		config EXTERNAL_KERNAL_LIBPTHREAD_FILE_SPEC
			string
			prompt "external-kernel-libpthread shared library files (use wildcards)"
			depends on EXTERNAL_KERNEL_TOOLCHAIN && PACKAGE_external-kernel-libpthread
			default "./lib/libpthread{-*.so,.so.*}"
	
		endmenu

	config PACKAGE_external-kernel-libresolv
		tristate "external-kernel-libresolv............................... resolver library"
		default y if DEFAULT_external-kernel-libresolv
		default m if ALL
		depends on EXTERNAL_KERNEL_TOOLCHAIN
		select PACKAGE_external-kernel-libgcc
		help
		 resolver library
		 Felix Fietkau <nbd@openwrt.org>


		menu "Configuration"
		depends on EXTERNAL_KERNEL_TOOLCHAIN && PACKAGE_external-kernel-libresolv
	
		config EXTERNAL_KERNAL_LIBRESOLV_FILE_SPEC
			string
			prompt "external-kernel-libresolv shared library files (use wildcards)"
			depends on EXTERNAL_KERNEL_TOOLCHAIN && PACKAGE_external-kernel-libresolv
			default "./lib/libresolv{-*.so,.so.*}"
	
		endmenu

	config PACKAGE_external-kernel-librt
		tristate "external-kernel-librt................ POSIX.1b RealTime extension library"
		default y if DEFAULT_external-kernel-librt
		default m if ALL
		depends on EXTERNAL_KERNEL_TOOLCHAIN
		select PACKAGE_external-kernel-libpthread
		select PACKAGE_external-kernel-libc
		help
		 POSIX.1b RealTime extension library
		 Felix Fietkau <nbd@openwrt.org>


		menu "Configuration"
		depends on EXTERNAL_KERNEL_TOOLCHAIN && PACKAGE_external-kernel-librt
	
		config EXTERNAL_KERNAL_LIBRT_FILE_SPEC
			string
			prompt "external-kernel-librt shared library files (use wildcards)"
			depends on EXTERNAL_KERNEL_TOOLCHAIN && PACKAGE_external-kernel-librt
			default "./lib/librt{-*.so,.so.*}"
	
		endmenu

	config PACKAGE_external-kernel-libssp
		tristate "external-kernel-libssp............... external-kernel-gcc support library"
		default y if DEFAULT_external-kernel-libssp
		default m if ALL
		depends on EXTERNAL_KERNEL_TOOLCHAIN
		help
		 external-kernel-gcc support library
		 http://gcc.gnu.org/
		 Felix Fietkau <nbd@openwrt.org>


		menu "Configuration"
			depends on EXTERNAL_KERNEL_TOOLCHAIN && PACKAGE_external-kernel-libssp
	
		config EXTERNAL_KERNAL_LIBSSP_FILE_SPEC
			string
			prompt "libssp shared library files (use wildcards)"
			depends on EXTERNAL_KERNEL_TOOLCHAIN && PACKAGE_external-kernel-libssp
			default "./lib/libssp.so.*"
	
		endmenu

	config PACKAGE_external-kernel-libstdcpp
		tristate "external-kernel-libstdcpp.................... GNU Standard C++ Library v3"
		default y if DEFAULT_external-kernel-libstdcpp
		default m if ALL
		depends on EXTERNAL_KERNEL_TOOLCHAIN
		help
		 GNU Standard C++ Library v3
		 http://gcc.gnu.org/
		 Felix Fietkau <nbd@openwrt.org>


		menu "Configuration"
		depends on EXTERNAL_KERNEL_TOOLCHAIN && PACKAGE_external-kernel-libstdcpp
	
		config EXTERNAL_KERNAL_LIBSTDCPP_FILE_SPEC
			string
			prompt "libstdc++ shared library files (use wildcards)"
			depends on EXTERNAL_KERNEL_TOOLCHAIN && PACKAGE_external-kernel-libstdcpp
			default "./lib/libstdc++.so.*"
	
		endmenu

	config PACKAGE_external-kernel-libthread-db
		tristate "external-kernel-libthread-db...... POSIX thread library debugging support"
		default y if DEFAULT_external-kernel-libthread-db
		default m if ALL
		select PACKAGE_external-kernel-libgcc
		depends on EXTERNAL_KERNEL_TOOLCHAIN
		help
		 POSIX thread library debugging support
		 Felix Fietkau <nbd@openwrt.org>

	config PACKAGE_firewall
		tristate "firewall................................................ OpenWrt firewall"
		default y if DEFAULT_firewall
		default m if ALL
		select PACKAGE_libc
		select PACKAGE_iptables
		select PACKAGE_kmod-ipt-nat
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_kmod-ipt-conntrack
		help
		 UCI based firewall for OpenWrt
		 http://openwrt.org/
		 Jo-Philipp Wich <xm@subsignal.org>

	config PACKAGE_hotplug2
		tristate "hotplug2"
		default y if DEFAULT_hotplug2
		default m if ALL
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libbsd if !(USE_UCLIBC||USE_MUSL)
		select PACKAGE_libc
		depends on !(!(USE_UCLIBC||USE_MUSL)) || USE_GLIBC
		help
		 Hotplug2 is a trivial replacement of some of the UDev functionality
		  in a tiny pack, intended for Linux early userspace: Init RAM FS and InitRD.
		  This is an implementation of Hotplug2-1.0-beta
		 http://isteve.bofh.cz/~isteve/hotplug2/
		 Felix Fietkau <nbd@openwrt.org>

	config PACKAGE_libc
		tristate "libc........................................................... C library"
		default y if DEFAULT_libc
		default m if ALL
		select PACKAGE_libgcc
		help
		 C library
		 Felix Fietkau <nbd@openwrt.org>


		menu "Configuration"
		depends on EXTERNAL_TOOLCHAIN && PACKAGE_libc
	
		config LIBC_ROOT_DIR
			string
			prompt "libc shared library base directory"
			depends on EXTERNAL_TOOLCHAIN && PACKAGE_libc
			default TOOLCHAIN_ROOT  if !NATIVE_TOOLCHAIN
			default "/"  if NATIVE_TOOLCHAIN
	
		config LIBC_FILE_SPEC
			string
			prompt "libc shared library files (use wildcards)"
			depends on EXTERNAL_TOOLCHAIN && PACKAGE_libc
			default "./lib/ld{-*.so,-*.so.*,-linux*.so.*} ./lib/lib{anl,c,uClibc,cidn,crypt,dl,m,nsl,nss_dns,nss_files,resolv,util}{-*.so,.so.*}"
	
		endmenu

	config PACKAGE_libgcc
		tristate "libgcc............................................... GCC support library"
		default y if DEFAULT_libgcc
		default m if ALL
		help
		 GCC support library
		 http://gcc.gnu.org/
		 Felix Fietkau <nbd@openwrt.org>


		menu "Configuration"
			depends on EXTERNAL_TOOLCHAIN && PACKAGE_libgcc
	
		config LIBGCC_ROOT_DIR
			string
			prompt "libgcc shared library base directory"
			depends on EXTERNAL_TOOLCHAIN && PACKAGE_libgcc
			default TOOLCHAIN_ROOT  if !NATIVE_TOOLCHAIN
			default "/"  if NATIVE_TOOLCHAIN
	
		config LIBGCC_FILE_SPEC
			string
			prompt "libgcc shared library files (use wildcards)"
			depends on EXTERNAL_TOOLCHAIN && PACKAGE_libgcc
			default "./lib/libgcc_s.so.*"
	
		endmenu

	config PACKAGE_libgfortran
		tristate "libgfortran..................................... GFortran support library"
		default y if DEFAULT_libgfortran
		default m if ALL
		depends on INSTALL_GFORTRAN
		help
		 GFortran support library
		 http://gcc.gnu.org/
		 Felix Fietkau <nbd@openwrt.org>


		menu "Configuration"
			depends on EXTERNAL_TOOLCHAIN && PACKAGE_libgfortran
	
		config LIBGFORTRAN_ROOT_DIR
			string
			prompt "libgfortran shared library base directory"
			depends on EXTERNAL_TOOLCHAIN && PACKAGE_libgfortran
			default TOOLCHAIN_ROOT  if !NATIVE_TOOLCHAIN
			default "/"  if NATIVE_TOOLCHAIN
	
		config LIBGFORTRAN_FILE_SPEC
			string
			prompt "libgfortran shared library files (use wildcards)"
			depends on EXTERNAL_TOOLCHAIN && PACKAGE_libgfortran
			default "./usr/lib/libgfortran.so.*"
	
		endmenu

	config PACKAGE_libpthread
		tristate "libpthread.......................................... POSIX thread library"
		default y if DEFAULT_libpthread
		default m if ALL
		select PACKAGE_libgcc
		help
		 POSIX thread library
		 Felix Fietkau <nbd@openwrt.org>


		menu "Configuration"
		depends on EXTERNAL_TOOLCHAIN && PACKAGE_libpthread
	
		config LIBPTHREAD_ROOT_DIR
			string
			prompt "libpthread shared library base directory"
			depends on EXTERNAL_TOOLCHAIN && PACKAGE_libpthread
			default TOOLCHAIN_ROOT  if !NATIVE_TOOLCHAIN
			default "/"  if NATIVE_TOOLCHAIN
	
		config LIBPTHREAD_FILE_SPEC
			string
			prompt "libpthread shared library files (use wildcards)"
			depends on EXTERNAL_TOOLCHAIN && PACKAGE_libpthread
			default "./lib/libpthread{-*.so,.so.*}"
	
		endmenu

	config PACKAGE_libresolv
		tristate "libresolv............................................... resolver library"
		default y if DEFAULT_libresolv
		default m if ALL
		select PACKAGE_libgcc
		help
		 resolver library
		 Felix Fietkau <nbd@openwrt.org>


		menu "Configuration"
		depends on EXTERNAL_TOOLCHAIN && PACKAGE_libresolv
	
		config LIBRESOLV_ROOT_DIR
			string
			prompt "libresolv shared library base directory"
			depends on EXTERNAL_TOOLCHAIN && PACKAGE_libresolv
			default TOOLCHAIN_ROOT  if !NATIVE_TOOLCHAIN
			default "/"  if NATIVE_TOOLCHAIN
	
		config LIBRESOLV_FILE_SPEC
			string
			prompt "libresolv shared library files (use wildcards)"
			depends on EXTERNAL_TOOLCHAIN && PACKAGE_libresolv
			default "./lib/libresolv{-*.so,.so.*}"
	
		endmenu

	config PACKAGE_librt
		tristate "librt................................ POSIX.1b RealTime extension library"
		default y if DEFAULT_librt
		default m if ALL
		select PACKAGE_libpthread
		help
		 POSIX.1b RealTime extension library
		 Felix Fietkau <nbd@openwrt.org>


		menu "Configuration"
		depends on EXTERNAL_TOOLCHAIN && PACKAGE_librt
	
		config LIBRT_ROOT_DIR
			string
			prompt "librt shared library base directory"
			depends on EXTERNAL_TOOLCHAIN && PACKAGE_librt
			default TOOLCHAIN_ROOT  if !NATIVE_TOOLCHAIN
			default "/"  if NATIVE_TOOLCHAIN
	
		config LIBRT_FILE_SPEC
			string
			prompt "librt shared library files (use wildcards)"
			depends on EXTERNAL_TOOLCHAIN && PACKAGE_librt
			default "./lib/librt{-*.so,.so.*}"
	
		endmenu

	config PACKAGE_libssp
		tristate "libssp............................................... GCC support library"
		default y if DEFAULT_libssp
		default m if ALL
		depends on SSP_SUPPORT
		help
		 GCC support library
		 http://gcc.gnu.org/
		 Felix Fietkau <nbd@openwrt.org>


		menu "Configuration"
			depends on EXTERNAL_TOOLCHAIN && PACKAGE_libssp
	
		config LIBSSP_ROOT_DIR
			string
			prompt "libssp shared library base directory"
			depends on EXTERNAL_TOOLCHAIN && PACKAGE_libssp
			default TOOLCHAIN_ROOT  if !NATIVE_TOOLCHAIN
			default "/"  if NATIVE_TOOLCHAIN
	
		config LIBSSP_FILE_SPEC
			string
			prompt "libssp shared library files (use wildcards)"
			depends on EXTERNAL_TOOLCHAIN && PACKAGE_libssp
			default "./lib/libssp.so.*"
	
		endmenu

	config PACKAGE_libstdcpp
		tristate "libstdcpp.................................... GNU Standard C++ Library v3"
		default y if DEFAULT_libstdcpp
		default m if ALL
		depends on INSTALL_LIBSTDCPP
		help
		 GNU Standard C++ Library v3
		 http://gcc.gnu.org/
		 Felix Fietkau <nbd@openwrt.org>


		menu "Configuration"
		depends on EXTERNAL_TOOLCHAIN && PACKAGE_libstdcpp
	
