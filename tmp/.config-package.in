			depends on EXTERNAL_TOOLCHAIN && PACKAGE_libstdcpp
			default "./lib/libstdc++.so.*"
	
		endmenu

	config PACKAGE_libthread-db
		tristate "libthread-db...................... POSIX thread library debugging support"
		default y if DEFAULT_libthread-db
		default m if ALL
		depends on !USE_MUSL
		help
		 POSIX thread library debugging support
		 Felix Fietkau <nbd@openwrt.org>

	config PACKAGE_logrotate
		tristate "logrotate..................... Utility which generates a lot of log files"
		default y if DEFAULT_logrotate
		default m if ALL
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libpopt
		select PACKAGE_libc
		help
		 Utility which generates a lot of log files
		 

	config PACKAGE_mkelfimage
		tristate 
		default y if DEFAULT_mkelfimage
		default y if TARGET_x86
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libpthread if USE_GLIBC
		depends on i386
		select PACKAGE_libc
		help
		 mkelfimage
		 

	config PACKAGE_mtd
		tristate "mtd............................... Update utility for trx firmware images"
		default y if DEFAULT_mtd
		default m if ALL
		select PACKAGE_libc
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_librt if USE_GLIBC
		help
		 This package contains an utility useful to upgrade from other firmware or 
		  older OpenWrt releases.
		 

	config PACKAGE_mtd-econet
		tristate "mtd-econet........................ Update utility for trx firmware images"
		default y if DEFAULT_mtd-econet
		default m if ALL
		select PACKAGE_libc
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_librt if USE_GLIBC
		help
		 This package contains an utility useful to upgrade from other firmware or 
		  older OpenWrt releases.
		 

	config PACKAGE_net-snmp
		tristate "net-snmp........................ Tools and libraries relating to the SNMP"
		default y if DEFAULT_net-snmp
		default m if ALL
		select PACKAGE_libc
		select PACKAGE_libzyutil if ZYXEL_SUPPORT_ZCFG
		select PACKAGE_libzcmd_tool
		select PACKAGE_glib2 if NETSNMP_MODSW
		select PACKAGE_librt
		select PACKAGE_libopenssl
		select PACKAGE_libjson
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libzcfg_msg if ZYXEL_SUPPORT_ZCFG
		select PACKAGE_zyee if NETSNMP_MODSW
		select PACKAGE_libzcfg_fe_schema if ZYXEL_SUPPORT_ZCFG
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_libzcfg_fe_rdm_access if ZYXEL_SUPPORT_ZCFG
		select PACKAGE_libcrypto
		select PACKAGE_libzcfg_fe_rdm_string if ZYXEL_SUPPORT_ZCFG
		select PACKAGE_libzcfg_fe_rdm_struct if ZYXEL_SUPPORT_ZCFG
		help
		 Tools and libraries relating to the SNMP
		 


		source "package/network/services/net-snmp/Config.in"

	config PACKAGE_netifd
		tristate "netifd.................... OpenWrt Network Interface Configuration Daemon"
		default y if DEFAULT_netifd
		default m if ALL
		select PACKAGE_libuci
		select PACKAGE_libnl-tiny
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_ubus
		select PACKAGE_libc
		select PACKAGE_jshn
		select PACKAGE_libubus
		select PACKAGE_libpthread if USE_GLIBC
		help
		 OpenWrt Network Interface Configuration Daemon
		 Felix Fietkau <nbd@openwrt.org>

	config PACKAGE_ntpclient
		tristate "ntpclient.............. An NTP (RFC-1305) client for unix-alike computers"
		default y if DEFAULT_ntpclient
		default m if ALL
		select PACKAGE_libc
		select PACKAGE_libzcfg_msg
		select PACKAGE_libzcfg_fe_rdm_access
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_librt
		select PACKAGE_librt if USE_GLIBC
		help
