menu "wide-dhcpv6"
	config PACKAGE_dhcp6c
		tristate "dhcp6c................................................ WIDE-DHCPv6 client"
		default y if DEFAULT_dhcp6c
		default m if ALL
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_libzcfg_fe_rdm_access
		select PACKAGE_libzcfg_msg
		select PACKAGE_libc
		select PACKAGE_libzcmd_tool
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libjson
		select PACKAGE_libzcfg_fe_rdm_struct
		help
		 WIDE-DHCPv6 client
		 https://sourceforge.net/projects/wide-dhcpv6/
		 Andrew Byrne <openwrt@andy.id.au>

	config PACKAGE_dhcp6s
		tristate "dhcp6s................................................ WIDE-DHCPv6 server"
		default y if DEFAULT_dhcp6s
		default m if ALL
		select PACKAGE_libzcfg_msg
		select PACKAGE_libc
		select PACKAGE_libzcmd_tool
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_libzcfg_fe_rdm_access
		select PACKAGE_libzcfg_fe_rdm_struct
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libjson
		help
		 WIDE-DHCPv6 is an open-source implementation of Dynamic Host Configuration Protocol
		 	for IPv6 (DHCPv6) originally developed by the KAME project. The implementation
		 	mainly conforms to the following standards: RFC3315,3319,3633,3646,4075,4272,etc.
		 
		 	This package installs the server component.
		 https://sourceforge.net/projects/wide-dhcpv6/
		 Andrew Byrne <openwrt@andy.id.au>

endmenu
	config PACKAGE_6distributed
		tristate "6distributed........................ IPv6 host prefix distribution daemon"
		default y if DEFAULT_6distributed
		default m if ALL
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_libubus
		select PACKAGE_kmod-ipv6
		select PACKAGE_libc
		help
		 6distributed is a daemon that distributes IPv6 prefixes locally across
		  downstream interfaces. It supports valid and preferred lifetimes and
		  delayed allocation so that an already acquired prefix can be distributed
		  on interfaces that come up later.
		 Steven Barth <steven@midlink.org>

	config PACKAGE_6in4
		tristate "6in4.................................. IPv6-in-IPv4 configuration support"
		default y if DEFAULT_6in4
		default m if ALL
		select PACKAGE_kmod-sit
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_kmod-ipv6
		select PACKAGE_libc
		help
		 Provides support for 6in4 tunnels in /etc/config/network.
		 Refer to http://wiki.openwrt.org/doc/uci/network for
		 configuration details.
		 Jo-Philipp Wich <xm@subsignal.org>

	config PACKAGE_6rd
		tristate "6rd............................................ 6rd configuration support"
		default y if DEFAULT_6rd
		default m if ALL
		select PACKAGE_kmod-sit
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_kmod-ipv6
		select PACKAGE_libc
		help
		 Provides support for 6rd tunnels in /etc/config/network.
		 Refer to http://wiki.openwrt.org/doc/uci/network for
		 configuration details.
		 Stéphan Kochen <stephan@kochen.nl>

	config PACKAGE_6relayd
		tristate "6relayd................. IPv6-Relay and Server (RD-, DHCPv6- & NDP-Proxy)"
		default y if DEFAULT_6relayd
		default m if ALL
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_kmod-ipv6
		select PACKAGE_libc
		help
		 6relayd is an IPv6-tool that relays IPv6-management protocols like router
		  discovery, neighbor discovery and DHCPv6 so that clients on routed (non-
		  bridged) interfaces can use the public address prefix, DHCPv6 and DNS-service
		  of a master interface. This is useful to avoid NAT in chained IPv6-routers.
		 
		  It can also be used as a lightweight router advertisement daemon and provide
		  stateless DHCPv6 service where size matters.
		 Steven Barth <steven@midlink.org>

	config PACKAGE_6to4
		tristate "6to4.................................. IPv6-to-IPv4 configuration support"
		default y if DEFAULT_6to4
		default m if ALL
		select PACKAGE_kmod-ipv6
		select PACKAGE_libc
		select PACKAGE_kmod-sit
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libpthread if USE_GLIBC
		help
		 Provides support for 6to4 tunnels in /etc/config/network.
		 Refer to http://wiki.openwrt.org/doc/uci/network for
		 configuration details.
		 Jo-Philipp Wich <xm@subsignal.org>

	config PACKAGE_ipv6-support
		tristate "ipv6-support................ Basic IPv6-support for Customer Edge Routers"
		default y if DEFAULT_ipv6-support
		default m if ALL
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_ip6tables
		select PACKAGE_libc
		select PACKAGE_ubus
		select PACKAGE_kmod-ipv6
		select PACKAGE_6relayd
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_6distributed
		select PACKAGE_odhcp6c
		help
		 This package provides basic IPv6 support including Router Discovery,
		 DHCPv6 (client & server), prefix delegation and distribution.
		 Steven Barth <steven@midlink.org>

	config PACKAGE_odhcp6c
		tristate "odhcp6c............................... Embedded DHCPv6-client for OpenWrt"
		default y if DEFAULT_odhcp6c
		default m if ALL
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_kmod-ipv6
		select PACKAGE_libc
		help
		 Embedded DHCPv6-client for OpenWrt
		 Steven Barth <steven@midlink.org>

	config PACKAGE_radvd
		tristate "radvd.................................. IPv6 Routing Advertisement Daemon"
		default y if DEFAULT_radvd
		default m if ALL
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_libc
		select PACKAGE_kmod-ipv6
		help
		 radvd is the router advertisement daemon for IPv6. It listens to router
		 solicitations and sends router advertisements as described in "Neighbor
		 Discovery for IP Version 6 (IPv6)" (RFC 4861).  With these advertisements hosts
		 can automatically configure their addresses and some other parameters. They also
		 can choose a default router based on these advertisements.
		 http://v6web.litech.org/radvd/
		 

	config PACKAGE_radvdump
		tristate "radvdump............................... IPv6 Routing Advertisement Dumper"
		default y if DEFAULT_radvdump
		default m if ALL
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_kmod-ipv6
		select PACKAGE_libc
		help
		 radvdump prints out the contents of incoming router advertisements sent by radvd
		 or some other software implementing (parts of) "Neighbor Discovery for IP
		 Version 6 (IPv6)" (RFC 4861).
		 http://v6web.litech.org/radvd/
		 

endmenu

