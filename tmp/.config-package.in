		 http://linuxwireless.org/
		 Felix Fietkau <nbd@openwrt.org>

	config PACKAGE_kmod-cfg80211
		tristate "kmod-cfg80211...................... cfg80211 - wireless configuration API"
		default y if DEFAULT_kmod-cfg80211
