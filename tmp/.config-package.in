menu "Routing and Redirection"
	config PACKAGE_ecmh
		tristate "ecmh....................................... IPV6 Multicast Routing Daemon"
		default y if DEFAULT_ecmh
		default m if ALL
		select PACKAGE_libc
		select IPV6
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_librt
		select PACKAGE_ip
		select PACKAGE_libpthread if USE_GLIBC
		help
		 Easy Cast du Multi Hub (ecmh) is a networking daemon 
		 	that acts as a full IPv6 MLDv1 and MLDv2 Multicast "Router".
		 

	config PACKAGE_igmpproxy
		tristate "igmpproxy....................................... Multicast Routing Daemon"
		default y if DEFAULT_igmpproxy
		default m if ALL
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_libc
		help
		 IGMPproxy is a simple dynamic Multicast Routing Daemon using
		 	only IGMP signalling (Internet Group Management Protocol).
		 http://sourceforge.net/projects/igmpproxy
		 

	config PACKAGE_ip
		tristate "ip............................................... Routing control utility"
		default y if DEFAULT_ip
		default m if ALL
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_libc
		select PACKAGE_external-kernel-libc if EXTERNAL_KERNEL_TOOLCHAIN
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libnl-tiny
		select PACKAGE_external-kernel-libgcc if EXTERNAL_KERNEL_TOOLCHAIN
		select PACKAGE_external-kernel-librt if EXTERNAL_KERNEL_TOOLCHAIN
		select PACKAGE_external-kernel-libpthread if EXTERNAL_KERNEL_TOOLCHAIN
		help
		 Routing control utility
		 http://linux-net.osdl.org/index.php/Iproute2
		 

	config PACKAGE_lldpd
		tristate "lldpd............................... Link Layer Discovery Protocol daemon"
		default y if DEFAULT_lldpd
		default m if ALL
		select PACKAGE_libc
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_libevent2
		help
		 LLDP (Link Layer Discovery Protocol) is an industry standard protocol designed
		 	to supplant proprietary Link-Layer protocols such as
		 	Extreme's EDP (Extreme Discovery Protocol) and
		 	CDP (Cisco Discovery Protocol).
		 	The goal of LLDP is to provide an inter-vendor compatible mechanism to deliver
		 	Link-Layer notifications to adjacent network devices.
		 https://github.com/vincentbernat/lldpd/wiki
		 Jo-Philipp Wich <jow@openwrt.org>

	config PACKAGE_relayd
		tristate "relayd................................ Transparent routing / relay daemon"
		default y if DEFAULT_relayd
		default m if ALL
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libc
		select PACKAGE_libubox
		help
		 Transparent routing / relay daemon
		 Felix Fietkau <nbd@openwrt.org>

endmenu
menu "VPN"
	config PACKAGE_xl2tpd
		tristate "xl2tpd....................... An L2TP (Layer 2 Tunneling Protocol) daemon"
		default y if DEFAULT_xl2tpd
		default m if ALL
		depends on PACKAGE_kmod-ppp
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_resolveip
		depends on (PACKAGE_ppp)
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_ppp-mod-pppol2tp
		select PACKAGE_libc
		help
		 l2tpd is the open source implementation of the L2TP tunneling protocol (RFC2661).
		 It does implement both LAC and LNS role in a L2TP networking architecture. The
		 main goal of this protocol is to tunnel PPP frame trough an IP network.
		 http://www.xelerance.com/software/xl2tpd/
		 Yousong Zhou <yszhou4tech@gmail.com>

endmenu
menu "Web Servers/Proxies"
	config PACKAGE_sockd
		tristate "sockd................................................. Dante SOCKS Daemon"
		default y if DEFAULT_sockd
		default m if ALL
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_libc
		help
		 Dante is a circuit-level firewall/proxy that can be used to provide convenient
		 and secure network connectivity, requiring only that the server Dante runs on
		 has external network connectivity. Dante is used daily by Fortune 100 companies
		 and large international organizations, either as a standard SOCKS server or as
		 a "reverse proxy". 
		 This package provides the Dante sockd daemon.
		 http://www.inet.no/dante/
		 Jo-Philipp Wich <jow@openwrt.org>

	config PACKAGE_socksify
		tristate "socksify.............................................. Dante SOCKS Client"
		default y if DEFAULT_socksify
		default m if ALL
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_libc
		help
		 Dante is a circuit-level firewall/proxy that can be used to provide convenient
		 and secure network connectivity, requiring only that the server Dante runs on
		 has external network connectivity. Dante is used daily by Fortune 100 companies
		 and large international organizations, either as a standard SOCKS server or as
		 a "reverse proxy". 
		 This package provides the Dante socksify client.
		 http://www.inet.no/dante/
		 Jo-Philipp Wich <jow@openwrt.org>

	config PACKAGE_uhttpd
		tristate "uhttpd........................ uHTTPd - tiny, single threaded HTTP server"
		default y if DEFAULT_uhttpd
		default m if ALL
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libubox
		select PACKAGE_libc
		help
		 uHTTPd is a tiny single threaded HTTP server with TLS, CGI and Lua
		  support. It is intended as a drop-in replacement for the Busybox
		  HTTP daemon.
		 Jo-Philipp Wich <jow@openwrt.org>


	  config PACKAGE_uhttpd_debug
	    bool "Build with debug messages"
	    default n

	config PACKAGE_uhttpd-mod-lua
		tristate "uhttpd-mod-lua... uHTTPd - tiny, single threaded HTTP server (Lua plugin)"
		default y if DEFAULT_uhttpd-mod-lua
		default m if ALL
		select PACKAGE_libc
		select PACKAGE_liblua
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_librt if USE_GLIBC
		depends on PACKAGE_uhttpd
		help
		 The Lua plugin adds a CGI-like Lua runtime interface to uHTTPd.
		 Jo-Philipp Wich <jow@openwrt.org>

	config PACKAGE_uhttpd-mod-tls
		tristate "uhttpd-mod-tls... uHTTPd - tiny, single threaded HTTP server (TLS plugin)"
		default y if DEFAULT_uhttpd-mod-tls
		default m if ALL
		select PACKAGE_libc
		depends on PACKAGE_uhttpd
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libopenssl if PACKAGE_uhttpd-mod-tls_openssl
		select PACKAGE_libcyassl if PACKAGE_uhttpd-mod-tls_cyassl
		help
		 The TLS plugin adds HTTPS support to uHTTPd.
		 Jo-Philipp Wich <jow@openwrt.org>


	  choice
	    depends on PACKAGE_uhttpd-mod-tls
	    prompt "TLS Provider"
	    default PACKAGE_uhttpd-mod-tls_cyassl
	
	    config PACKAGE_uhttpd-mod-tls_cyassl
	      bool "CyaSSL"
	
	    config PACKAGE_uhttpd-mod-tls_openssl
	      bool "OpenSSL"
	  endchoice

	config PACKAGE_uhttpd-mod-ubus
		tristate "uhttpd-mod-ubus. uHTTPd - tiny, single threaded HTTP server (ubus plugin)"
		default y if DEFAULT_uhttpd-mod-ubus
		default m if ALL
		select PACKAGE_libc
		select PACKAGE_libblobmsg-json
		depends on PACKAGE_uhttpd
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libubus
		select PACKAGE_libpthread if USE_GLIBC
		help
		 The ubus plugin adds a HTTP/JSON RPC proxy for ubus and publishes the
		  session.* namespace and procedures.
		 Jo-Philipp Wich <jow@openwrt.org>

endmenu
menu "dial-in/up"
	config PACKAGE_rp-pppoe-client
