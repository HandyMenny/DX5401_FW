menu "Firewall"
	config PACKAGE_arptables
		tristate "arptables....................................... ARP firewalling software"
		default y if DEFAULT_arptables
		default m if ALL
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libc
		select PACKAGE_kmod-arptables
		help
		 ARP firewalling software
		 http://ebtables.sourceforge.net
		 

	config PACKAGE_conntrack-tools
		tristate "conntrack-tools...................... Connection tracking userspace tools"
		default y if DEFAULT_conntrack-tools
		default m if ALL
		select PACKAGE_libnetfilter-cthelper
		select PACKAGE_libnetfilter-cttimeout
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libc
		select PACKAGE_libnetfilter-conntrack
		select PACKAGE_libnetfilter_queue
		select PACKAGE_libpthread if USE_GLIBC
		help
		 The conntrack-tools are a set of free software userspace tools for Linux
		  that allow system administrators interact with the Connection Tracking
		  System, which is the module that provides stateful packet inspection for
		  iptables. The conntrack-tools are the userspace daemon conntrackd and the
		  command line interface conntrack.
		 http://conntrack-tools.netfilter.org/
		 Jo-Philipp Wich <jow@openwrt.org>

	config PACKAGE_ebtables
		tristate "ebtables................. Ethernet bridge firewall administration utility"
		default y if DEFAULT_ebtables
		default m if ALL
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_external-kernel-libgcc if EXTERNAL_KERNEL_TOOLCHAIN
		select PACKAGE_kmod-ebtables
		select PACKAGE_external-kernel-librt if EXTERNAL_KERNEL_TOOLCHAIN
		select PACKAGE_libc
		select PACKAGE_external-kernel-libc if EXTERNAL_KERNEL_TOOLCHAIN
		select PACKAGE_external-kernel-libpthread if EXTERNAL_KERNEL_TOOLCHAIN
		help
		 The ebtables program is a filtering tool for a bridging firewall. The
		 	filtering is focussed on the Link Layer Ethernet frame fields. Apart
		 	from filtering, it also gives the ability to alter the Ethernet MAC
		 	addresses and implement a brouter.
		 http://ebtables.sourceforge.net/
		 

	config PACKAGE_ebtables-utils
		tristate "ebtables-utils........................... ebtables save/restore utilities"
		default y if DEFAULT_ebtables-utils
		default m if ALL
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_libc
		select PACKAGE_external-kernel-libc if EXTERNAL_KERNEL_TOOLCHAIN
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_kmod-ebtables
		select PACKAGE_external-kernel-libgcc if EXTERNAL_KERNEL_TOOLCHAIN
		depends on PACKAGE_ebtables
		select PACKAGE_external-kernel-librt if EXTERNAL_KERNEL_TOOLCHAIN
		select PACKAGE_external-kernel-libpthread if EXTERNAL_KERNEL_TOOLCHAIN
		help
		 The ebtables program is a filtering tool for a bridging firewall. The
		 	filtering is focussed on the Link Layer Ethernet frame fields. Apart
		 	from filtering, it also gives the ability to alter the Ethernet MAC
		 	addresses and implement a brouter.
		 http://ebtables.sourceforge.net/
		 

	menuconfig PACKAGE_iptables
		tristate "iptables............................... IPv4 firewall administration tool"
		default y if DEFAULT_iptables
		default m if ALL
		select PACKAGE_kmod-ipt-core
		select PACKAGE_libc
		select PACKAGE_libxtables
		select PACKAGE_libip4tc
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libpthread if USE_GLIBC
		help
		 IPv4 firewall administration tool.
		 
		  Matches:
		   - icmp
		   - tcp
		   - udp
		   - comment
		   - limit
		   - mac
		   - multiport
		 
		  Targets:
		   - ACCEPT
		   - DROP
		   - REJECT
		   - LOG
		   - TCPMSS
		 
		  Tables:
		   - filter
		   - mangle
		 
		 http://netfilter.org/
		 

	config PACKAGE_iptables-mod-conntrack-extra
		tristate "iptables-mod-conntrack-extra........ Extra connection tracking extensions"
		default y if DEFAULT_iptables-mod-conntrack-extra
		default m if ALL
		select PACKAGE_libc
		depends on PACKAGE_kmod-ipt-core
		select PACKAGE_kmod-ipt-conntrack-extra
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_librt if USE_GLIBC
		depends on PACKAGE_iptables
		help
		 Extra iptables extensions for connection tracking.
		 
		  Matches:
		   - connbytes
		   - connmark
		   - recent
		   - helper
		 
		  Targets:
		   - CONNMARK
		 
		 http://netfilter.org/
		 

	config PACKAGE_iptables-mod-extra
		tristate "iptables-mod-extra....................... Other extra iptables extensions"
		default y if DEFAULT_iptables-mod-extra
		default m if ALL
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libpthread if USE_GLIBC
		depends on PACKAGE_iptables
		select PACKAGE_libc
		select PACKAGE_kmod-ipt-extra
		depends on PACKAGE_kmod-ipt-core
		help
		 Other extra iptables extensions.
		 
		  Matches:
		   - addrtype
		   - condition
		   - owner
		   - physdev (if ebtables is enabled)
		   - pkttype
		   - quota
		 
		 http://netfilter.org/
		 

	config PACKAGE_iptables-mod-filter
		tristate "iptables-mod-filter........................ Content inspection extensions"
		default y if DEFAULT_iptables-mod-filter
		default m if ALL
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_kmod-ipt-filter
		select PACKAGE_libpthread if USE_GLIBC
		depends on PACKAGE_iptables
		depends on PACKAGE_kmod-ipt-core
		select PACKAGE_libc
		help
		 iptables extensions for packet content inspection.
		 Includes support for:
		 
		  Matches:
		   - layer7
		   - string
		 
		 http://netfilter.org/
		 

	config PACKAGE_iptables-mod-hashlimit
		tristate "iptables-mod-hashlimit................................ hashlimit matching"
		default y if DEFAULT_iptables-mod-hashlimit
		default m if ALL
		select PACKAGE_kmod-ipt-hashlimit
		depends on PACKAGE_iptables
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_libc
		help
		 iptables extensions for hashlimit matching
		 
		  Matches:
		   - hashlimit
		 
		 http://netfilter.org/
		 

	config PACKAGE_iptables-mod-ipopt
		tristate "iptables-mod-ipopt........................... IP/Packet option extensions"
		default y if DEFAULT_iptables-mod-ipopt
		default m if ALL
		depends on PACKAGE_iptables
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_libpthread if USE_GLIBC
		select PACKAGE_kmod-ipt-ipopt
		depends on PACKAGE_kmod-ipt-core
		select PACKAGE_libc
		help
		 iptables extensions for matching/changing IP packet options.
		 
		  Matches:
		   - dscp
		   - ecn
		   - length
		   - mark
		   - statistic
		   - tcpmss
		   - time
		   - unclean
		   - hl
		 ifeq ("", "y")
		   - zextmark
		 endif
		   - connmark
		 
		  Targets:
		   - DSCP
		   - CLASSIFY
		   - ECN
		   - MARK
		   - HL
		 ifeq ("", "y")
		   - ZEXTMARK
		 endif
		   - CONNMARK
		 
		 http://netfilter.org/
		 

	config PACKAGE_iptables-mod-iprange
		tristate "iptables-mod-iprange.................................. IP range extension"
		default y if DEFAULT_iptables-mod-iprange
		default m if ALL
		select PACKAGE_libpthread if USE_GLIBC
		depends on PACKAGE_iptables
		depends on PACKAGE_kmod-ipt-core
		select PACKAGE_libc
		select PACKAGE_librt if USE_GLIBC
		select PACKAGE_kmod-ipt-iprange
		help
		 iptables extensions for matching ip ranges.
		 
		  Matches:
		   - iprange
		 
		 http://netfilter.org/
		 

	config PACKAGE_iptables-mod-ipsec
		tristate "iptables-mod-ipsec...................................... IPsec extensions"
